datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

//
// USER
//
model User {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  role Role @default(CANDIDATE)

  companyName String?

  hrPhone String?

  bookings Booking[]
}

//
// ROLE ENUM
//
enum Role {
  ADMIN
  CANDIDATE
}

//
// SLOT
//
model Slot {
  id        Int      @id @default(autoincrement())
  startTime DateTime
  endTime   DateTime

  duration Int @default(60)

  isBooked Boolean @default(false)

  bookings Booking[]
}

//
// BOOKING
//
model Booking {
  id Int @id @default(autoincrement())

  userId Int
  slotId Int

  companyName String?
  round       String?
  hrName      String?
  hrPhone     String?
  hrEmail     String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  slot Slot @relation(fields: [slotId], references: [id])
}
